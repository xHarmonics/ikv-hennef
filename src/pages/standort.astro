---
import BaseLayout from "../layouts/BaseLayout.astro";
import { addressCityLine, addressGoogleMapsUrl, routes, site } from "../data/site";
---

<BaseLayout
  title={`Standort - ${site.shortName}`}
  description={`Standort und Anschrift des ${site.legalName}.`}
  active="location"
>
  <section
    class="mx-auto min-h-[calc(100svh-8rem)] w-full max-w-[87.5rem] px-container pt-20 pb-32"
  >
    <div class="grid gap-10 md:grid-cols-[0.9fr_1.1fr] md:items-start">
      <div>
        <p class="label-caps mb-6 text-secondary">Standort</p>
        <h1 class="font-organic-title text-headline-mobile text-primary md:text-headline">
          {site.shortName}
          <span class="block text-on-surface-variant">vor Ort</span>
        </h1>
        <p class="mt-8 text-body-lg text-on-surface-variant">
          Der Sitz des Vereins ist in Hennef. Für Besuchszeiten und Veranstaltungen bitte vorher
          Kontakt aufnehmen.
        </p>
      </div>

      <article class="paper-card rounded-[2rem] p-8 md:p-12">
        <p class="label-caps mb-4 text-secondary">Anschrift</p>
        <a
          class="group block"
          href={addressGoogleMapsUrl}
          rel="noreferrer"
          target="_blank"
          aria-label={`${site.legalName}, ${site.address.street}, ${addressCityLine} in Google Maps öffnen`}
        >
          <address
            class="font-organic-title text-headline-md text-primary not-italic transition-colors group-hover:text-secondary"
          >
            {site.legalName}<br />
            {site.address.street}<br />
            {addressCityLine}
          </address>
        </a>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            class="organic-button label-caps inline-flex items-center gap-2 bg-primary px-6 py-3 text-on-primary"
            href={addressGoogleMapsUrl}
            rel="noreferrer"
            target="_blank"
          >
            <span class="material-symbols-outlined text-[1.125rem]" aria-hidden="true">map</span>
            Google Maps
          </a>
          <a
            class="organic-button label-caps inline-flex bg-surface-container px-6 py-3 text-primary"
            href={routes.contact}
          >
            Kontakt aufnehmen
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
