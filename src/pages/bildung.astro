---
import BaseLayout from "../layouts/BaseLayout.astro";
import { educationPrograms, site } from "../data/site";
---

<BaseLayout
  title={`Bildung - ${site.shortName}`}
  description={`${site.shortName}: Sprachkurse, Nachhilfe und islamische Lehre.`}
  active="education"
>
  <section
    class="mx-auto min-h-[calc(100svh-8rem)] w-full max-w-[87.5rem] px-container pt-20 pb-32"
  >
    <div class="mb-16 max-w-2xl">
      <p class="label-caps mb-6 text-secondary">Bildung</p>
      <h1 class="font-organic-title text-headline-mobile text-primary md:text-headline">
        Räume für
        <span class="block text-on-surface-variant">Wachstum</span>
      </h1>
      <p class="mt-8 text-body-lg text-on-surface-variant">
        Bildungsarbeit verbindet beim {site.shortName} praktische Unterstützung mit kultureller und religiöser
        Orientierung.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-3 md:items-start">
      {
        educationPrograms.map((program, index) => (
          <article
            class:list={[
              "glass-panel rounded-[2rem] p-8 md:min-h-[22rem] md:p-10",
              index === 1 ? "md:mt-12" : "",
              index === 2 ? "md:mt-4" : "",
            ]}
          >
            <h2 class="font-organic-title mb-4 text-headline-md text-primary">{program.title}</h2>
            <p class="text-body text-on-surface-variant">{program.text}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
